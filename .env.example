# Uygulamanın yayınlanacağı tam URL (Örn: https://denetim.al)
# OAuth veya tam yol gerektiren bazı özellikler için gerekebilir.
APP_URL="http://localhost:3000"

# Sunucu Portu (Varsayılan: 3000)
PORT=3000

# Node Environment (Üretim modu için 'production' kalsın)
NODE_ENV="production"

# --- NOTLAR ---
# 1. Bu dosyayı '.env' olarak kopyalayın.
# 2. Gerçek API anahtarınızı asla GitHub vb. yerlere yüklemeyin.
# 3. Sunucuda çalıştırmak için 'node dist/server.cjs' komutunu kullanın.
