rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidFirm(data) {
      return data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.get('vkn', 'default') is string && data.get('vkn', 'default').size() <= 50 &&
             data.get('vd', 'default') is string && data.get('vd', 'default').size() <= 100 &&
             data.get('sector', 'default') is string && data.get('sector', 'default').size() <= 100 &&
             data.get('mizanSummary', 'default') is string &&
             data.get('gelirTablosuSummary', 'default') is string &&
             data.get('bilancoSummary', 'default') is string &&
             data.get('beyannameSummary', 'default') is string &&
             data.get('risk', 'default') is string && data.get('risk', 'default').size() <= 50 &&
             data.get('riskColor', 'default') is string && data.get('riskColor', 'default').size() <= 50 &&
             data.get('manager', 'default') is string &&
             data.get('contact', 'default') is string;
    }

    match /firms/{firmId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid && isValidId(firmId);
      allow create: if isSignedIn() && isValidFirm(incoming()) && isValidId(firmId);
      allow update: if isSignedIn() && isValidId(firmId) && isValidFirm(incoming()) && existing().userId == request.auth.uid && incoming().userId == existing().userId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'vkn', 'vd', 'sector', 'mizanSummary', 'gelirTablosuSummary', 'bilancoSummary', 'beyannameSummary', 'risk', 'riskColor', 'manager', 'contact']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid && isValidId(firmId);
      allow list: if isSignedIn() && request.auth.uid != null;
    }
  }
}
